# Server
PORT=5000

# MySQL Database (use your managed/production DB host in production — never localhost)
DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=shiva_sai_traders

# JWT
JWT_SECRET=change_this_to_a_long_random_secret

# Comma-separated list of extra allowed origins for CORS, in addition to
# localhost and *.vercel.app / *.onrender.com which are always allowed.
# Example: https://myapp.com,https://www.myapp.com
ALLOWED_ORIGINS=
